{
    "name": "lararoxy/lararoxy",
    "description": "Declarative API gateway and proxy package for Laravel",
    "keywords": [
        "laravel",
        "api-gateway",
        "proxy",
        "bff",
        "api-proxy",
        "reverse-proxy"
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "laravel/sanctum": "^4.3"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Lararoxy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lararoxy\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lararoxy\\LararoxyServiceProvider"
            ],
            "aliases": {
                "Lararoxy": "Lararoxy\\Facades\\Lararoxy",
                "Proxy": "Lararoxy\\Facades\\Proxy"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": "@php vendor/bin/pint --ansi",
        "lint:check": "@php vendor/bin/pint --test --ansi",
        "test": "@php vendor/bin/phpunit",
        "test:unit": "@php vendor/bin/phpunit --testsuite=Unit",
        "test:feature": "@php vendor/bin/phpunit --testsuite=Feature",
        "test:filter": "@php vendor/bin/phpunit --filter",
        "coverage": "@php vendor/bin/phpunit --coverage-text",
        "coverage:html": "@php vendor/bin/phpunit --coverage-html=coverage-html",
        "coverage:min": "@php vendor/bin/phpunit --coverage-text --coverage-clover=coverage.xml",
        "check": [
            "@lint:check",
            "@coverage:min"
        ],
        "fix": [
            "@lint",
            "@test"
        ]
    }
}